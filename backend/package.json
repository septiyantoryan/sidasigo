{
  "name": "sidasigo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:inovasi": "tsx prisma/seed-inovasi-daerah.ts",
    "db:seed:krenova": "tsx prisma/seed-krenova.ts",
    "db:seed:riset": "tsx prisma/seed-riset.ts",
    "db:seed:berita": "tsx prisma/seed-berita.ts",
    "db:seed:download": "tsx prisma/seed-download.ts",
    "db:seed:demo": "tsx prisma/seed-inovasi-daerah.ts && tsx prisma/seed-krenova.ts && tsx prisma/seed-riset.ts && tsx prisma/seed-berita.ts && tsx prisma/seed-download.ts"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^3.0.2",
    "better-auth": "^1.3.8",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "mariadb": "^3.4.5",
    "morgan": "^1.11.0",
    "multer": "^2.0.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/supertest": "^6.0.3",
    "prisma": "^7.0.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
